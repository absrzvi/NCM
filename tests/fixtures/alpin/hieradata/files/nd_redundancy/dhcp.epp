---
dhcp:
  classes:
    Wing-7562:
      match_conditions:
        - 'substring(option vendor-class-identifier, 0, 13) = "WingAP.AP7562"'
      options:
        AP-adoption: pool1=172.30.44.75;level=2;rf-domain=Brain<%= lookup('train_identification_api::external_id') %>
        AP-protocol: ftp://anonymous:21net@ftp.onboard
        AP-path: /firmware/AP7562-active-firmware.img
    accesspoint:
      match_conditions:
        - '(substring (option host-name, 0, 8) = "CYBOX-AP")'
        # Eltec vendor mac list
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "0:0:5b")'
        # Extreme vendor mac list
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "20:9e:f7")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "74:67:f7")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "b8:50:1")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "48:9b:d5")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "94:9b:2c")'
        # Westermo
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "0:11:b4")'
    switch:
      match_conditions:
        # lantech
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "28:60:46")'
        # moxa
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "00:90:e8")'
        # men
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "74:8f:4d")'
        # oring
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) = "7c:70:bc")'
    devices:
      boolean_operator: and
      match_conditions:
        - '(substring (option host-name, 0, 8)  != "CYBOX-AP")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "0:0:5b")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "28:60:46")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "00:90:e8")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "0:10:2")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "0:18:7d")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "0:c:c6")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "0:c:42")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "74:8f:4d")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "20:9e:f7")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "74:67:f7")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "b8:50:1")'
        - '(binary-to-ascii(16,8,":",substring (hardware, 1, 3)) != "94:9b:2c")'

  location: /tmp/dhcp
  literal: |-
    option captive-portal code 114 = string;
    option AP-protocol code 186 = string;
    option AP-path code 187 = string;
    option AP-adoption code 191 = string;
